# Copy to `backend/.env` for local development (pydantic reads backend/.env when cwd is backend).

# --- Security ---
SECRET_KEY=replace-with-openssl-rand-hex-32
# DEBUG=true

# --- Database (SQLite default; use Postgres in production) ---
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/medical_ai

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Optional OpenAI for LLM explanations + /assistant/chat ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Seed admin on first startup (optional) ---
# ADMIN_EMAIL=admin@hospital.local
# ADMIN_PASSWORD=ChangeMeNow123!
